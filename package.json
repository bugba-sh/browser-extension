{
  "name": "bugba-sh",
  "displayName": "Bugba sh",
  "version": "0.0.1",
  "description": "Instant team feedback sessions",
  "author": "Jimmy Loughran <hello@jim.ie>",
  "scripts": {
    "dev": "plasmo dev --src-path=.",
    "build": "plasmo build --src-path=.",
    "package": "plasmo package --src-path=.",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "tabs",
      "tabGroups",
      "sidePanel",
      "storage"
    ],
    "host_permissions": [
      "https://*.atlassian.net/*"
    ]
  }
}
